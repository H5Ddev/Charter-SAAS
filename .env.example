# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# Azure SQL connection string — format: sqlserver://HOST:1433;database=DB;user=USER;password=PASS;encrypt=true
# For local dev with Docker: sqlserver://localhost:1433;database=aerocomm;user=sa;password=AeroComm_Dev1!;encrypt=false;trustServerCertificate=true
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Azure Cache for Redis connection string
# For local dev with Docker: redis://localhost:6379
REDIS_URL=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Azure AD B2C ─────────────────────────────────────────────────────────────
# Obtain from Azure Portal > Azure AD B2C > App registrations
AZURE_AD_B2C_TENANT_NAME=
AZURE_AD_B2C_CLIENT_ID=
AZURE_AD_B2C_CLIENT_SECRET=
AZURE_AD_B2C_POLICY_SIGNIN=B2C_1_signin
AZURE_AD_B2C_POLICY_SIGNUP=B2C_1_signup

# ── Azure Key Vault ──────────────────────────────────────────────────────────
# Format: https://<vault-name>.vault.azure.net/
# In production, the app uses Managed Identity; these creds are for local dev only
AZURE_KEY_VAULT_URL=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── Azure Service Bus ────────────────────────────────────────────────────────
# Obtain from Azure Portal > Service Bus namespace > Shared access policies
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_AUTOMATION=automation-events
AZURE_SERVICE_BUS_QUEUE_NOTIFICATIONS=notification-events

# ── Azure Blob Storage ───────────────────────────────────────────────────────
# For local dev with Azurite, use the well-known dev connection string (see Azurite docs)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_DOCUMENTS=documents
AZURE_STORAGE_CONTAINER_PHOTOS=photos

# ── Azure Container Registry ─────────────────────────────────────────────────
# Format: <registry-name>.azurecr.io
ACR_LOGIN_SERVER=
ACR_USERNAME=
ACR_PASSWORD=

# ── Twilio ──────────────────────────────────────────────────────────────────
# Obtain from https://console.twilio.com
# Account SID and Auth Token are on the Twilio Console dashboard
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=
# Webhook Secret for request validation — set in Twilio console webhook settings
TWILIO_WEBHOOK_SECRET=

# ── SendGrid ─────────────────────────────────────────────────────────────────
# Obtain from https://app.sendgrid.com/settings/api_keys
# Requires "Mail Send" permission at minimum
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=AeroComm

# ── Slack ─────────────────────────────────────────────────────────────────────
# Obtain from https://api.slack.com/apps > Your App > Basic Information > App Credentials
SLACK_SIGNING_SECRET=

# ── MS Teams ──────────────────────────────────────────────────────────────────
# Secret for validating incoming Teams webhook payloads
MSTEAMS_WEBHOOK_SECRET=

# ── DocuSign ─────────────────────────────────────────────────────────────────
# Obtain from https://admindemo.docusign.com/apps-and-keys
# HMAC key configured in DocuSign Connect webhook settings
DOCUSIGN_HMAC_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_INTEGRATION_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Obtain from https://dashboard.stripe.com/apikeys
# Webhook secret from https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── ForeFlight (Stub) ─────────────────────────────────────────────────────────
# TODO: Obtain from ForeFlight developer program at https://developer.foreflight.com
# Currently stubbed — integration not yet implemented
FOREFLIGHT_API_KEY=
FOREFLIGHT_BASE_URL=https://plan.foreflight.com/api

# ── Weather API (Stub) ────────────────────────────────────────────────────────
# National Weather Service API (no key required for NWS)
# For commercial weather APIs (e.g. Tomorrow.io, OpenWeatherMap) provide key below
WEATHER_API_KEY=
WEATHER_API_BASE_URL=https://api.weather.gov

# ── MFA / TOTP ────────────────────────────────────────────────────────────────
# App name shown in authenticator apps (e.g. Google Authenticator, Authy)
TOTP_APP_NAME=AeroComm
TOTP_ISSUER=AeroComm

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window per IP
RATE_LIMIT_MAX=100

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Session / CSRF ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CSRF_SECRET=
SESSION_SECRET=
