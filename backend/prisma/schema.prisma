generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum TenantPlan {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  DISPATCHER
  SALES_AGENT
  OWNER
  PASSENGER
  READ_ONLY
}

enum ContactType {
  OWNER
  PASSENGER
  BOTH
}

enum PreferredChannel {
  SMS
  EMAIL
  WHATSAPP
  PHONE
}

enum TripStatus {
  INQUIRY
  QUOTED
  BOOKED
  CONFIRMED
  DEPARTED
  ARRIVED
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum TicketSource {
  EMAIL
  SMS
  WEBFORM
  MANUAL
  SMS_INBOUND
  WHATSAPP
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_CLIENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationChannel {
  SMS
  EMAIL
  WHATSAPP
  SLACK
  TEAMS
  IN_APP
}


enum IntegrationType {
  TWILIO
  SENDGRID
  SLACK
  MSTEAMS
  DOCUSIGN
  STRIPE
  FOREFLIGHT
  WEATHER_API
}

enum WebhookEventStatus {
  PENDING
  PROCESSED
  FAILED
  SKIPPED
}

enum AutomationTriggerType {
  TRIP_STATUS_CHANGED
  TRIP_DELAY_FLAGGED
  QUOTE_CREATED
  QUOTE_ACCEPTED
  QUOTE_EXPIRED
  QUOTE_DECLINED
  TICKET_OPENED
  TICKET_SLA_BREACHED
  TICKET_ESCALATED
  CONTACT_CREATED
  CONTACT_FIELD_UPDATED
  SCHEDULE_CRON
  INBOUND_WEBHOOK
  PAYMENT_STATUS_CHANGED
}

enum AutomationActionType {
  SEND_SMS
  SEND_EMAIL
  SEND_WHATSAPP
  SEND_SLACK
  SEND_TEAMS
  CREATE_TICKET
  UPDATE_TRIP_FIELD
  UPDATE_CONTACT_FIELD
  FIRE_WEBHOOK
  CHAIN_AUTOMATION
  WAIT_DELAY
  GENERATE_PDF
  ADD_NOTE
}

enum ConditionOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  GT
  LT
  IS_EMPTY
  IS_NOT_EMPTY
  IN
  NOT_IN
}

enum ConditionGroupOperator {
  AND
  OR
}

enum AutomationExecutionStatus {
  SUCCESS
  FAILED
  SKIPPED
}

enum AircraftAvailabilityType {
  MAINTENANCE
  CHARTER_BLOCK
  OTHER
}

enum ScheduledMessageStatus {
  PENDING
  SENT
  CANCELLED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenant
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id           String     @id @default(cuid())
  tenantId     String     @default("")
  name         String
  slug         String     @unique
  plan         TenantPlan @default(TRIAL)
  isActive     Boolean    @default(true)
  settings     Json       @default("{}")
  customFields Json?
  timezone     String     @default("America/Chicago")
  supportPhone String?
  supportEmail String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  users                 User[]
  contacts              Contact[]
  aircraft              Aircraft[]
  trips                 Trip[]
  quotes                Quote[]
  tickets               Ticket[]
  automations           Automation[]
  notificationTemplates NotificationTemplate[]
  integrations          Integration[]
  auditLogs             AuditLog[]
  organizations         Organization[]

  @@index([slug])
  @@index([isActive])
  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// Users & Auth
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(READ_ONLY)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  mfaSettings UserMfaSettings?
  auditLogs   AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

model UserMfaSettings {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String   @unique
  totpSecret  String?
  totpEnabled Boolean  @default(false)
  smsEnabled  Boolean  @default(false)
  smsPhone    String?
  backupCodes Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@map("user_mfa_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// RBAC
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  name      String   @unique
  resource  String
  action    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Organizations & Contacts
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  industry     String?
  website      String?
  phone        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  zipCode      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  contacts Contact[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("organizations")
}

model Contact {
  id               String           @id @default(cuid())
  tenantId         String
  organizationId   String?
  type             ContactType      @default(PASSENGER)
  firstName        String
  lastName         String
  email            String?
  phone            String?
  whatsappPhone    String?
  secondaryPhone   String?
  addressLine1     String?
  city             String?
  state            String?
  country          String?
  zipCode          String?
  tags             String           @default("[]")
  customFields     Json?
  preferredChannel PreferredChannel @default(EMAIL)
  doNotContact     Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  notes          ContactNote[]
  documents      ContactDocument[]
  trips          TripPassenger[]
  tickets        Ticket[]
  quotes         Quote[]
  tagMaps        ContactTagMap[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, type])
  @@index([organizationId])
  @@map("contacts")
}

model ContactNote {
  id        String    @id @default(cuid())
  tenantId  String
  contactId String
  userId    String
  content   String
  isPrivate Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@map("contact_notes")
}

model ContactDocument {
  id         String    @id @default(cuid())
  tenantId   String
  contactId  String
  fileName   String
  fileType   String
  blobUrl    String
  uploadedBy String
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@map("contact_documents")
}

model ContactTag {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  color     String    @default("#3B82F6")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  contactMaps ContactTagMap[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("contact_tags")
}

model ContactTagMap {
  contactId String
  tagId     String

  contact Contact    @relation(fields: [contactId], references: [id])
  tag     ContactTag @relation(fields: [tagId], references: [id])

  @@id([contactId, tagId])
  @@map("contact_tag_maps")
}

// ─────────────────────────────────────────────────────────────────────────────
// Aircraft
// ─────────────────────────────────────────────────────────────────────────────

model Aircraft {
  id            String    @id @default(cuid())
  tenantId      String
  tailNumber    String
  make          String
  model         String
  year          Int?
  seats         Int
  rangeNm       Int?
  amenities     Json?
  homeBaseIcao  String?
  ownerId       String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  owner         Contact?              @relation(fields: [ownerId], references: [id])
  photos        AircraftPhoto[]
  availabilities AircraftAvailability[]
  trips         Trip[]
  tripLegs      TripLeg[]

  @@unique([tenantId, tailNumber])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([ownerId])
  @@map("aircraft")
}

model AircraftPhoto {
  id         String    @id @default(cuid())
  tenantId   String
  aircraftId String
  blobUrl    String
  caption    String?
  isPrimary  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  aircraft Aircraft @relation(fields: [aircraftId], references: [id])

  @@index([tenantId])
  @@index([tenantId, aircraftId])
  @@map("aircraft_photos")
}

model AircraftAvailability {
  id         String                   @id @default(cuid())
  tenantId   String
  aircraftId String
  startAt    DateTime
  endAt      DateTime
  type       AircraftAvailabilityType @default(OTHER)
  notes      String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  deletedAt  DateTime?

  aircraft Aircraft @relation(fields: [aircraftId], references: [id])

  @@index([tenantId])
  @@index([tenantId, aircraftId])
  @@index([tenantId, aircraftId, startAt, endAt])
  @@map("aircraft_availabilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// Trips
// ─────────────────────────────────────────────────────────────────────────────

model Trip {
  id                String     @id @default(cuid())
  tenantId          String
  aircraftId        String?
  status            TripStatus @default(INQUIRY)
  originIcao        String
  destinationIcao   String
  departureAt       DateTime
  arrivalAt         DateTime?
  returnDepartureAt DateTime?
  returnArrivalAt   DateTime?
  fboName           String?
  fboAddress        String?
  boardingTime      DateTime?
  pilots            String?
  returnPilots      String?
  returnFbo         String?
  paxCount          Int        @default(0)
  notes             String?
  isDelayed         Boolean    @default(false)
  delayNotes        String?
  surveyLink        String?
  quoteId           String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  aircraft      Aircraft?           @relation(fields: [aircraftId], references: [id])
  quote         Quote?              @relation(fields: [quoteId], references: [id])
  legs          TripLeg[]
  passengers    TripPassenger[]
  statusHistory TripStatusHistory[]
  tickets       Ticket[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, departureAt])
  @@index([aircraftId])
  @@index([quoteId])
  @@map("trips")
}

model TripLeg {
  id              String    @id @default(cuid())
  tenantId        String
  tripId          String
  legNumber       Int
  originIcao      String
  destinationIcao String
  departureAt     DateTime
  arrivalAt       DateTime?
  aircraftId      String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  trip     Trip      @relation(fields: [tripId], references: [id])
  aircraft Aircraft? @relation(fields: [aircraftId], references: [id])

  @@index([tenantId])
  @@index([tenantId, tripId])
  @@map("trip_legs")
}

model TripPassenger {
  id        String    @id @default(cuid())
  tenantId  String
  tripId    String
  contactId String
  isPrimary Boolean   @default(false)
  seatNumber String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  trip    Trip    @relation(fields: [tripId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([tripId, contactId])
  @@index([tenantId])
  @@index([tenantId, tripId])
  @@index([tenantId, contactId])
  @@map("trip_passengers")
}

model TripStatusHistory {
  id         String     @id @default(cuid())
  tenantId   String
  tripId     String
  fromStatus TripStatus?
  toStatus   TripStatus
  changedBy  String
  notes      String?
  changedAt  DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  trip Trip @relation(fields: [tripId], references: [id])

  @@index([tenantId])
  @@index([tenantId, tripId])
  @@map("trip_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// Quotes
// ─────────────────────────────────────────────────────────────────────────────

model Quote {
  id           String      @id @default(cuid())
  tenantId     String
  contactId    String
  status       QuoteStatus @default(DRAFT)
  validUntil   DateTime?
  basePrice    Decimal     @db.Decimal(12, 2)
  totalPrice   Decimal     @db.Decimal(12, 2)
  currency     String      @default("USD")
  notes        String?
  signatureUrl String?
  signedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  contact   Contact         @relation(fields: [contactId], references: [id])
  trips     Trip[]
  lineItems QuoteLineItem[]
  versions  QuoteVersion[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@map("quotes")
}

model QuoteLineItem {
  id          String    @id @default(cuid())
  tenantId    String
  quoteId     String
  description String
  quantity    Decimal   @db.Decimal(10, 3)
  unitPrice   Decimal   @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  category    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  quote Quote @relation(fields: [quoteId], references: [id])

  @@index([tenantId])
  @@index([tenantId, quoteId])
  @@map("quote_line_items")
}

model QuoteVersion {
  id            String   @id @default(cuid())
  tenantId      String
  quoteId       String
  versionNumber Int
  snapshotData  Json
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  quote Quote @relation(fields: [quoteId], references: [id])

  @@index([tenantId])
  @@index([tenantId, quoteId])
  @@map("quote_versions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Ticketing
// ─────────────────────────────────────────────────────────────────────────────

model Ticket {
  id          String         @id @default(cuid())
  tenantId    String
  contactId   String?
  tripId      String?
  quoteId     String?
  source      TicketSource   @default(MANUAL)
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(NORMAL)
  title       String
  body        String?
  assignedTo  String?
  slaBreachAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  contact     Contact?          @relation(fields: [contactId], references: [id])
  trip        Trip?             @relation(fields: [tripId], references: [id])
  messages    TicketMessage[]
  attachments TicketAttachment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId, tripId])
  @@index([tenantId, assignedTo])
  @@map("tickets")
}

model TicketMessage {
  id         String    @id @default(cuid())
  tenantId   String
  ticketId   String
  userId     String?
  contactId  String?
  content    String
  isInternal Boolean   @default(false)
  channel    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@map("ticket_messages")
}

model TicketAttachment {
  id         String    @id @default(cuid())
  tenantId   String
  ticketId   String
  fileName   String
  fileType   String
  blobUrl    String
  uploadedBy String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@map("ticket_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Automations
// ─────────────────────────────────────────────────────────────────────────────

model Automation {
  id            String                @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  enabled       Boolean               @default(true)
  isDryRun      Boolean               @default(false)
  isSystem      Boolean               @default(false)
  createdById   String?
  triggerType   AutomationTriggerType @default(TRIP_STATUS_CHANGED)
  triggerConfig Json                  @default("{}")
  conditions    Json                  @default("[]")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deletedAt     DateTime?

  tenant          Tenant                     @relation(fields: [tenantId], references: [id])
  conditionGroups   AutomationConditionGroup[]
  actions           AutomationAction[]
  executionLogs     AutomationExecutionLog[]
  trigger           AutomationTrigger?
  scheduledMessages ScheduledMessage[]

  @@index([tenantId])
  @@index([tenantId, enabled])
  @@index([tenantId, triggerType])
  @@map("automations")
}

model AutomationTrigger {
  id           String                @id @default(cuid())
  tenantId     String?
  automationId String                @unique
  eventType    AutomationTriggerType
  filters      Json                  @default("{}")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?

  automation Automation @relation(fields: [automationId], references: [id])

  @@index([tenantId])
  @@map("automation_triggers")
}

model AutomationConditionGroup {
  id           String                 @id @default(cuid())
  tenantId     String?
  automationId String
  operator     ConditionGroupOperator @default(AND)
  parentGroupId String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deletedAt    DateTime?

  automation   Automation               @relation(fields: [automationId], references: [id])
  parentGroup  AutomationConditionGroup? @relation("NestedGroups", fields: [parentGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childGroups  AutomationConditionGroup[] @relation("NestedGroups")
  conditions   AutomationCondition[]

  @@index([tenantId])
  @@index([tenantId, automationId])
  @@map("automation_condition_groups")
}

model AutomationCondition {
  id               String            @id @default(cuid())
  tenantId         String?
  conditionGroupId String
  field            String
  operator         ConditionOperator @default(EQUALS)
  value            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  conditionGroup AutomationConditionGroup @relation(fields: [conditionGroupId], references: [id])

  @@index([tenantId])
  @@index([conditionGroupId])
  @@map("automation_conditions")
}

model AutomationAction {
  id               String               @id @default(cuid())
  tenantId         String?
  automationId     String
  sequence         Int
  actionType       AutomationActionType
  config           Json                 @default("{}")
  delayRelativeTo  String?
  delayOffsetMs    Int?                 @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?

  automation Automation @relation(fields: [automationId], references: [id])

  @@index([tenantId])
  @@index([tenantId, automationId])
  @@map("automation_actions")
}

model AutomationExecutionLog {
  id           String                    @id @default(cuid())
  tenantId     String
  automationId String
  triggeredAt  DateTime                  @default(now())
  entityType   String?
  entityId     String?
  status       AutomationExecutionStatus @default(SUCCESS)
  actionsRun   Int                       @default(0)
  errorMessage String?
  duration     Int?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  deletedAt    DateTime?

  automation        Automation         @relation(fields: [automationId], references: [id])
  scheduledMessages ScheduledMessage[]

  @@index([tenantId])
  @@index([tenantId, automationId])
  @@index([tenantId, status])
  @@map("automation_execution_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notification Templates
// ─────────────────────────────────────────────────────────────────────────────

model NotificationTemplate {
  id          String              @id @default(cuid())
  tenantId    String
  name        String
  description String?
  channel     NotificationChannel
  subject     String?
  body        String
  isSystem    Boolean             @default(false)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, channel])
  @@index([tenantId, isSystem])
  @@map("notification_templates")
}

// Global variable registry — not per-tenant, not per-template.
// Used by the automation builder UI for {{token}} autocomplete.
model TemplateVariable {
  id          String   @id @default(cuid())
  token       String   @unique   // e.g. "{{passenger.firstName}}"
  description String
  entityType  String             // "CONTACT" | "TRIP" | "TENANT"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("template_variables")
}

// ─────────────────────────────────────────────────────────────────────────────
// Integrations
// ─────────────────────────────────────────────────────────────────────────────

model Integration {
  id        String          @id @default(cuid())
  tenantId  String
  name      String
  type      IntegrationType
  isActive  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  config        IntegrationConfig?
  webhookEvents WebhookEvent[]

  @@unique([tenantId, type])
  @@index([tenantId])
  @@index([tenantId, type])
  @@map("integrations")
}

model IntegrationConfig {
  id            String    @id @default(cuid())
  tenantId      String
  integrationId String    @unique
  settings      Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  integration Integration @relation(fields: [integrationId], references: [id])

  @@index([tenantId])
  @@index([tenantId, integrationId])
  @@map("integration_configs")
}

model WebhookEvent {
  id            String             @id @default(cuid())
  tenantId      String
  integrationId String
  eventType     String
  rawBody       Json
  processedAt   DateTime?
  status        WebhookEventStatus @default(PENDING)
  error         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  integration Integration @relation(fields: [integrationId], references: [id])

  @@index([tenantId])
  @@index([tenantId, integrationId])
  @@index([tenantId, status])
  @@map("webhook_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Scheduled Messages
// ─────────────────────────────────────────────────────────────────────────────

model ScheduledMessage {
  id                       String               @id @default(cuid())
  tenantId                 String
  automationId             String
  automationExecutionLogId String?
  scheduledFor             DateTime
  status                   ScheduledMessageStatus @default(PENDING)
  actionType               AutomationActionType
  actionConfig             Json
  referenceEntityType      String
  referenceEntityId        String
  serviceBusSequenceNumber String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  deletedAt                DateTime?

  automation     Automation              @relation(fields: [automationId], references: [id])
  executionLog   AutomationExecutionLog? @relation(fields: [automationExecutionLogId], references: [id])

  @@index([tenantId])
  @@index([tenantId, automationId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledFor])
  @@index([referenceEntityId])
  @@map("scheduled_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit Logs
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  diff       Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
