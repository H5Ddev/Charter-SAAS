generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// NOTE: SQL Server connector does not support Prisma enums or Json types.
// All enum fields use String with application-level validation.
// All Json fields use String (store as JSON string, parse in application).

// ─────────────────────────────────────────────────────────────────────────────
// Tenant
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id           String    @id @default(cuid())
  tenantId     String    @default("")
  name         String
  slug         String    @unique
  plan         String    @default("TRIAL")
  isActive     Boolean   @default(true)
  settings     String    @default("{}")
  customFields String?
  timezone     String    @default("America/Chicago")
  supportPhone String?
  supportEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  users                 User[]
  contacts              Contact[]
  aircraft              Aircraft[]
  trips                 Trip[]
  quotes                Quote[]
  tickets               Ticket[]
  automations           Automation[]
  notificationTemplates NotificationTemplate[]
  integrations          Integration[]
  auditLogs             AuditLog[]
  organizations         Organization[]
  crewMembers           CrewMember[]
  crewGroups            CrewGroup[]
  aircraftClasses       AircraftClass[]

  @@index([slug])
  @@index([isActive])
  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// Users & Auth
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         String    @default("READ_ONLY")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mfaSettings    UserMfaSettings?
  auditLogs      AuditLog[]
  ticketMessages TicketMessage[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

model UserMfaSettings {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String    @unique
  totpSecret  String?
  totpEnabled Boolean   @default(false)
  smsEnabled  Boolean   @default(false)
  smsPhone    String?
  backupCodes String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([userId])
  @@map("user_mfa_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Organizations & Contacts
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  industry     String?
  website      String?
  phone        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  zipCode      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contacts Contact[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("organizations")
}

model Contact {
  id               String    @id @default(cuid())
  tenantId         String
  organizationId   String?
  type             String    @default("PASSENGER")
  firstName        String
  lastName         String
  email            String?
  phone            String?
  whatsappPhone    String?
  secondaryPhone   String?
  addressLine1     String?
  city             String?
  state            String?
  country          String?
  zipCode          String?
  tags             String    @default("[]")
  customFields     String?
  preferredChannel   String    @default("EMAIL")
  doNotContact       Boolean   @default(false)
  smsOptIn           Boolean   @default(false)
  smsOptInAt         DateTime?
  smsOptOutAt        DateTime?
  whatsappOptIn      Boolean   @default(false)
  whatsappOptInAt    DateTime?
  whatsappOptOutAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  notes          ContactNote[]
  documents      ContactDocument[]
  trips          TripPassenger[]
  tickets        Ticket[]
  ticketMessages TicketMessage[]
  quotes         Quote[]
  tagMaps        ContactTagMap[]
  aircraft       Aircraft[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, type])
  @@index([organizationId])
  @@map("contacts")
}

model ContactNote {
  id        String    @id @default(cuid())
  tenantId  String
  contactId String
  userId    String
  content   String
  isPrivate Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@map("contact_notes")
}

model ContactDocument {
  id         String    @id @default(cuid())
  tenantId   String
  contactId  String
  fileName   String
  fileType   String
  blobUrl    String
  uploadedBy String
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@map("contact_documents")
}

model ContactTag {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  color     String    @default("#3B82F6")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  contactMaps ContactTagMap[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("contact_tags")
}

model ContactTagMap {
  contactId String
  tagId     String

  contact Contact    @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tag     ContactTag @relation(fields: [tagId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([contactId, tagId])
  @@map("contact_tag_maps")
}

// ─────────────────────────────────────────────────────────────────────────────
// Aircraft
// ─────────────────────────────────────────────────────────────────────────────

model Aircraft {
  id           String    @id @default(cuid())
  tenantId     String
  tailNumber   String
  make         String
  model        String
  year         Int?
  seats        Int
  rangeNm      Int?
  amenities    String?
  homeBaseIcao String?
  ownerId      String?
  isActive     Boolean   @default(true)
  costPerHour    Decimal?  @db.Decimal(12, 2)
  hourlyRate     Decimal?  @db.Decimal(12, 2)
  basePrice      Decimal?  @db.Decimal(12, 2)
  airframeHours  Float?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tenant             Tenant                 @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  owner              Contact?               @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  photos             AircraftPhoto[]
  availabilities     AircraftAvailability[]
  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  crewGroups         CrewGroup[]
  aircraftClassId    String?
  aircraftClass      AircraftClass?         @relation(fields: [aircraftClassId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenantId, tailNumber])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([ownerId])
  @@map("aircraft")
}

model AircraftPhoto {
  id         String    @id @default(cuid())
  tenantId   String
  aircraftId String
  blobUrl    String
  caption    String?
  isPrimary  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  aircraft Aircraft @relation(fields: [aircraftId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, aircraftId])
  @@map("aircraft_photos")
}

model AircraftAvailability {
  id         String    @id @default(cuid())
  tenantId   String
  aircraftId String
  startAt    DateTime
  endAt      DateTime
  type       String    @default("OTHER")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  aircraft Aircraft @relation(fields: [aircraftId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, aircraftId])
  @@index([tenantId, aircraftId, startAt, endAt])
  @@map("aircraft_availabilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// Crew
// ─────────────────────────────────────────────────────────────────────────────

model CrewMember {
  id            String    @id @default(cuid())
  tenantId      String
  firstName     String
  lastName      String
  email         String?
  phone         String?
  role          String    // CAPTAIN, FIRST_OFFICER, FLIGHT_ATTENDANT, DISPATCHER, MECHANIC, OTHER
  licenseNumber String?
  licenseType   String?
  typeRatings   String?   // JSON array stored as string
  medicalClass  String?
  medicalExpiry DateTime?
  licenseExpiry DateTime?
  isActive      Boolean   @default(true)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tripAssignments  TripCrewAssignment[]
  documents        CrewDocument[]
  groupMemberships CrewGroupMember[]

  @@index([tenantId])
  @@index([tenantId, role])
  @@map("crew_members")
}

model CrewDocument {
  id           String    @id @default(cuid())
  tenantId     String
  crewMemberId String
  type         String
  name         String
  expiryDate   DateTime?
  fileUrl      String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  crewMember CrewMember @relation(fields: [crewMemberId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([crewMemberId])
  @@map("crew_documents")
}

model TripCrewAssignment {
  id           String   @id @default(cuid())
  tenantId     String
  tripId       String
  crewMemberId String
  role         String
  createdAt    DateTime @default(now())

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  crewMember CrewMember @relation(fields: [crewMemberId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tripId, crewMemberId])
  @@index([tenantId])
  @@index([tripId])
  @@map("trip_crew_assignments")
}

model CrewGroup {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  aircraftId  String?
  minPax      Int?
  maxPax      Int?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  aircraft Aircraft?         @relation(fields: [aircraftId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members  CrewGroupMember[]

  @@index([tenantId])
  @@index([aircraftId])
  @@map("crew_groups")
}

model CrewGroupMember {
  id           String   @id @default(cuid())
  tenantId     String
  groupId      String
  crewMemberId String
  createdAt    DateTime @default(now())

  group      CrewGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  crewMember CrewMember @relation(fields: [crewMemberId], references: [id], onDelete: Cascade)

  @@unique([groupId, crewMemberId])
  @@index([tenantId])
  @@index([crewMemberId])
  @@map("crew_group_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// Aircraft Classes
// ─────────────────────────────────────────────────────────────────────────────

model AircraftClass {
  id                 String    @id @default(cuid())
  tenantId           String
  name               String                        // e.g. "Heavy Jet", "Light Jet"
  description        String?
  regulatoryCategory String?                       // e.g. "Part 135", "Part 121"
  minSeats           Int?
  maxSeats           Int?
  minRangeNm         Int?
  maxRangeNm         Int?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  crewReqs     AircraftClassCrewReq[]
  aircraft     Aircraft[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("aircraft_classes")
}

model AircraftClassCrewReq {
  id          String  @id @default(cuid())
  classId     String
  role        String                              // CAPTAIN, FIRST_OFFICER, FLIGHT_ATTENDANT, etc.
  minCount    Int     @default(1)                 // minimum crew members of this role
  perPax      Int?                                // if set: add 1 of this role per N pax (e.g. 1 FA per 20 pax)

  aircraftClass AircraftClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@map("aircraft_class_crew_reqs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Maintenance
// ─────────────────────────────────────────────────────────────────────────────

model MaintenanceRecord {
  id                     String    @id @default(cuid())
  tenantId               String
  aircraftId             String
  type                   String
  title                  String
  description            String?
  status                 String    @default("SCHEDULED")
  scheduledAt            DateTime?
  completedAt            DateTime?
  vendor                 String?
  cost                   Decimal?  @db.Decimal(12, 2)
  airframeHoursAtService Float?
  nextDueHours           Float?
  nextDueDate            DateTime?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  aircraft Aircraft @relation(fields: [aircraftId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, aircraftId])
  @@index([tenantId, status])
  @@map("maintenance_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// Trips
// ─────────────────────────────────────────────────────────────────────────────

model Trip {
  id                String    @id @default(cuid())
  tenantId          String
  aircraftId        String?
  status            String    @default("INQUIRY")
  originIcao        String
  destinationIcao   String
  departureAt       DateTime
  arrivalAt         DateTime?
  fboName           String?
  fboAddress        String?
  boardingTime      DateTime?
  paxCount          Int       @default(0)
  notes             String?
  isDelayed         Boolean   @default(false)
  delayNotes        String?
  surveyLink        String?
  quoteId           String?
  returnTripId      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // NOTE: returnTripId is NOT @unique because SQL Server UNIQUE constraints
  // only allow one NULL value, which breaks `prisma db push` on any table
  // with >1 existing row. Uniqueness is enforced in the service layer
  // (see trips.service.create — round trips are always created atomically).
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  aircraft        Aircraft?            @relation(fields: [aircraftId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quote           Quote?               @relation(fields: [quoteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  returnTrip      Trip?                @relation("TripRoundTrip", fields: [returnTripId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  outboundTrip    Trip[]               @relation("TripRoundTrip")
  passengers      TripPassenger[]
  statusHistory   TripStatusHistory[]
  tickets         Ticket[]
  crewAssignments TripCrewAssignment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, departureAt])
  @@index([aircraftId])
  @@index([quoteId])
  @@map("trips")
}

model TripPassenger {
  id         String    @id @default(cuid())
  tenantId   String
  tripId     String
  contactId  String
  isPrimary  Boolean   @default(false)
  seatNumber String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  trip    Trip    @relation(fields: [tripId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tripId, contactId])
  @@index([tenantId])
  @@index([tenantId, tripId])
  @@index([tenantId, contactId])
  @@map("trip_passengers")
}

model TripStatusHistory {
  id         String    @id @default(cuid())
  tenantId   String
  tripId     String
  fromStatus String?
  toStatus   String
  changedBy  String
  notes      String?
  changedAt  DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, tripId])
  @@map("trip_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// Quotes
// ─────────────────────────────────────────────────────────────────────────────

model Quote {
  id              String    @id @default(cuid())
  tenantId        String
  contactId       String
  reference       String?
  status          String    @default("DRAFT")
  originIcao      String?
  destinationIcao String?
  tripType        String?
  departureDate   DateTime?
  returnDate      DateTime?
  validUntil      DateTime?
  basePrice       Decimal   @db.Decimal(12, 2)
  totalPrice      Decimal   @db.Decimal(12, 2)
  currency        String    @default("USD")
  passengers      Int?
  notes           String?
  signatureUrl    String?
  signedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contact   Contact         @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips     Trip[]
  tickets   Ticket[]
  lineItems QuoteLineItem[]
  versions  QuoteVersion[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@map("quotes")
}

model QuoteLineItem {
  id          String    @id @default(cuid())
  tenantId    String
  quoteId     String
  description String
  quantity    Decimal   @db.Decimal(10, 3)
  unitPrice   Decimal   @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  category    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, quoteId])
  @@map("quote_line_items")
}

model QuoteVersion {
  id            String    @id @default(cuid())
  tenantId      String
  quoteId       String
  versionNumber Int
  snapshotData  String
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, quoteId])
  @@map("quote_versions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Ticketing
// ─────────────────────────────────────────────────────────────────────────────

model Ticket {
  id          String    @id @default(cuid())
  tenantId    String
  contactId   String?
  tripId      String?
  quoteId     String?
  source      String    @default("MANUAL")
  status      String    @default("OPEN")
  priority    String    @default("NORMAL")
  title       String
  body        String?
  assignedTo  String?
  slaBreachAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contact     Contact?           @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trip        Trip?              @relation(fields: [tripId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quote       Quote?             @relation(fields: [quoteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages    TicketMessage[]
  attachments TicketAttachment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId, tripId])
  @@index([tenantId, quoteId])
  @@index([tenantId, assignedTo])
  @@map("tickets")
}

model TicketMessage {
  id         String    @id @default(cuid())
  tenantId   String
  ticketId   String
  userId     String?
  contactId  String?
  content    String
  isInternal Boolean   @default(false)
  channel    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  ticket  Ticket   @relation(fields: [ticketId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user    User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@index([userId])
  @@index([contactId])
  @@map("ticket_messages")
}

model TicketAttachment {
  id         String    @id @default(cuid())
  tenantId   String
  ticketId   String
  fileName   String
  fileType   String
  blobUrl    String
  uploadedBy String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@map("ticket_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Automations
// ─────────────────────────────────────────────────────────────────────────────

model Automation {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  enabled       Boolean   @default(true)
  isDryRun      Boolean   @default(false)
  isSystem      Boolean   @default(false)
  createdById   String?
  triggerType   String    @default("TRIP_STATUS_CHANGED")
  triggerConfig String    @default("{}")
  conditions    String    @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  conditionGroups   AutomationConditionGroup[]
  actions           AutomationAction[]
  executionLogs     AutomationExecutionLog[]
  trigger           AutomationTrigger?
  scheduledMessages ScheduledMessage[]

  @@index([tenantId])
  @@index([tenantId, enabled])
  @@index([tenantId, triggerType])
  @@map("automations")
}

model AutomationTrigger {
  id           String    @id @default(cuid())
  tenantId     String
  automationId String    @unique
  eventType    String
  filters      String    @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  automation Automation @relation(fields: [automationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@map("automation_triggers")
}

model AutomationConditionGroup {
  id            String    @id @default(cuid())
  tenantId      String
  automationId  String
  operator      String    @default("AND")
  parentGroupId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  automation  Automation                 @relation(fields: [automationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentGroup AutomationConditionGroup?  @relation("NestedGroups", fields: [parentGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childGroups AutomationConditionGroup[] @relation("NestedGroups")
  conditions  AutomationCondition[]

  @@index([tenantId])
  @@index([tenantId, automationId])
  @@map("automation_condition_groups")
}

model AutomationCondition {
  id               String    @id @default(cuid())
  tenantId         String
  conditionGroupId String
  field            String
  operator         String    @default("EQUALS")
  value            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  conditionGroup AutomationConditionGroup @relation(fields: [conditionGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([conditionGroupId])
  @@map("automation_conditions")
}

model AutomationAction {
  id              String    @id @default(cuid())
  tenantId        String
  automationId    String
  sequence        Int
  actionType      String
  config          String    @default("{}")
  delayRelativeTo String?
  delayOffsetMs   Int?      @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  automation Automation @relation(fields: [automationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, automationId])
  @@map("automation_actions")
}

model AutomationExecutionLog {
  id           String    @id @default(cuid())
  tenantId     String
  automationId String
  triggeredAt  DateTime  @default(now())
  entityType   String?
  entityId     String?
  status       String    @default("SUCCESS")
  actionsRun   Int       @default(0)
  errorMessage String?
  duration     Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  automation        Automation         @relation(fields: [automationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scheduledMessages ScheduledMessage[]

  @@index([tenantId])
  @@index([tenantId, automationId])
  @@index([tenantId, status])
  @@map("automation_execution_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notification Templates
// ─────────────────────────────────────────────────────────────────────────────

model NotificationTemplate {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  channel     String
  subject     String?
  body        String
  isSystem    Boolean   @default(false)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, channel])
  @@index([tenantId, isSystem])
  @@map("notification_templates")
}

model TemplateVariable {
  id          String   @id @default(cuid())
  token       String   @unique
  description String
  entityType  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("template_variables")
}

// ─────────────────────────────────────────────────────────────────────────────
// Integrations
// ─────────────────────────────────────────────────────────────────────────────

model Integration {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  type      String
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  config        IntegrationConfig?
  webhookEvents WebhookEvent[]

  @@unique([tenantId, type])
  @@index([tenantId])
  @@index([tenantId, type])
  @@map("integrations")
}

model IntegrationConfig {
  id            String    @id @default(cuid())
  tenantId      String
  integrationId String    @unique
  settings      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, integrationId])
  @@map("integration_configs")
}

model WebhookEvent {
  id            String    @id @default(cuid())
  tenantId      String
  integrationId String
  eventType     String
  rawBody       String
  processedAt   DateTime?
  status        String    @default("PENDING")
  error         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, integrationId])
  @@index([tenantId, status])
  @@map("webhook_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Scheduled Messages
// ─────────────────────────────────────────────────────────────────────────────

model ScheduledMessage {
  id                       String    @id @default(cuid())
  tenantId                 String
  automationId             String
  automationExecutionLogId String?
  scheduledFor             DateTime
  status                   String    @default("PENDING")
  actionType               String
  actionConfig             String
  referenceEntityType      String
  referenceEntityId        String
  serviceBusSequenceNumber String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  automation   Automation              @relation(fields: [automationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  executionLog AutomationExecutionLog? @relation(fields: [automationExecutionLogId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, automationId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledFor])
  @@index([referenceEntityId])
  @@map("scheduled_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// Airport (shared reference data — no tenantId, seeded from OurAirports.com)
// ─────────────────────────────────────────────────────────────────────────────

model Airport {
  id           Int     @id @default(autoincrement())
  icaoCode     String  @unique
  iataCode     String?
  name         String
  municipality String?
  isoCountry   String
  type         String
  latitudeDeg  Float?
  longitudeDeg Float?

  @@index([icaoCode])
  @@map("airports")
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit Logs
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  diff       String?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user   User?  @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
